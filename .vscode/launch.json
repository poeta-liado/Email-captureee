    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Python Debugger: Current File with Arguments",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": "${command:pickArgs}"
        },
        {
            "type": "hmmm",
            "request": "launch",
            "name": "Debug HMMM",
            "program": "${file}",
            "isBinary": false
        },
        {
            "type": "hmmm",
            "request": "launch",
            "name": "Debug HMMM (Binary)",
            "program": "${file}",
            "isBinary": true
        },
        {
            "name": "Debug HMMM",
            "type": "hmmm",
            "request": "launch",
            "program": "${file}",
            "isBinary": false
        }
    ]
}